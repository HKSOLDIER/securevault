# Copy to .env for local development
# On Railway: set these in Variables tab

# Database (Railway auto-provides DATABASE_URL)
DATABASE_URL=jdbc:postgresql://localhost:5432/securevault
DATABASE_USERNAME=neondb_owner
DATABASE_PASSWORD=npg_vyLUa3q9fFKH

# JWT — generate with: openssl rand -base64 64
JWT_SECRET=your-256-bit-random-secret-minimum-32-chars-never-use-default-value

# Pepper — separate random secret from JWT secret
PEPPER_SECRET=your-random-pepper-value-also-minimum-32-chars

# CORS — comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173,https://your-app.vercel.app

# Server
PORT=8080
